{"word":"arm","us_ipa":"/ɑːm/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/arm-us.mp3","uk_audio":"","short_translation":"Cánh Tay","senses":[{"pos":"Noun","definition":"The portion of the upper human appendage, from the shoulder to the wrist and sometimes including the hand.","translation":"Phần trên của cơ thể con người, từ vai đến cổ tay và đôi khi bao gồm cả bàn tay.","examples":[{"en":"She stood with her right arm extended and her palm forward to indicate “Stop!”","vi":""}]},{"pos":"Noun","definition":"The extended portion of the upper limb, from the shoulder to the elbow.","translation":"Phần mở rộng của chi trên, từ vai đến khuỷu tay.","examples":[{"en":"The arm and forearm are parts of the upper limb in the human body.","vi":""}]},{"pos":"Verb","definition":"To take by the arm; to take up in one's arms.","translation":"Để nắm lấy cánh tay; để ôm lấy trong vòng tay của một người.","examples":[]}],"source":"Free Dictionary API"}{"word":"leg","us_ipa":"/leɪɡ/","uk_ipa":"/lɛɡ/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/leg-1-au.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/leg-1-uk.mp3","short_translation":"Chân","senses":[{"pos":"Noun","definition":"A limb or appendage that an animal uses for support or locomotion.","translation":"Một chi hoặc phần phụ mà động vật sử dụng để hỗ trợ hoặc vận động.","examples":[{"en":"{{ux|en|Insects have six legs.}","vi":""}]},{"pos":"Noun","definition":"In humans, the lower limb extending from the groin to the ankle.","translation":"Ở người, chi dưới kéo dài từ háng đến mắt cá chân.","examples":[{"en":"Dan won't be able to come to the party, since he broke his leg last week and is now on crutches.","vi":""}]},{"pos":"Verb","definition":"To remove the legs from an animal carcass.","translation":"Để loại bỏ chân khỏi xác động vật.","examples":[]},{"pos":"Verb","definition":"To build legs onto a platform or stage for support.","translation":"Để dựng chân lên bệ hoặc sân khấu để hỗ trợ.","examples":[]}],"source":"Free Dictionary API"}{"word":"hello","us_ipa":"/həˈloʊ/","uk_ipa":"/həˈləʊ/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/hello-au.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/hello-uk.mp3","short_translation":"Xin Chào","senses":[{"pos":"Noun","definition":"\"Hello!\" or an equivalent greeting.","translation":"\"Xin chào!\" hoặc một lời chào tương đương.","examples":[]},{"pos":"Verb","definition":"To greet with \"hello\".","translation":"Để chào bằng \"xin chào\".","examples":[]},{"pos":"Interjection","definition":"A greeting (salutation) said when meeting someone or acknowledging someone’s arrival or presence.","translation":"Lời chào (chào) được nói khi gặp ai đó hoặc thừa nhận sự đến hoặc có mặt của ai đó.","examples":[{"en":"Hello, everyone.","vi":""}]},{"pos":"Interjection","definition":"A greeting used when answering the telephone.","translation":"Lời chào dùng khi trả lời điện thoại.","examples":[{"en":"Hello? How may I help you?","vi":""}]}],"source":"Free Dictionary API"}{"word":"convenient","us_ipa":"/kənˈviːniənt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/convenient-us.mp3","uk_audio":"","short_translation":"Thuận Lợi","senses":[{"pos":"Adjective","definition":"Serving to reduce a difficulty, or accessible with minimum difficulty; expedient.","translation":"Phục vụ để giảm bớt độ khó hoặc có thể truy cập được với độ khó tối thiểu; thiết thực.","examples":[{"en":"Fast food might be convenient, but it's also very unhealthy.","vi":""}]},{"pos":"Adjective","definition":"Fit; suitable; appropriate.","translation":"Phù hợp; thích hợp; phù hợp.","examples":[]}],"source":"Free Dictionary API"}{"word":"foster","us_ipa":"/ˈfɒstə/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/foster-au.mp3","uk_audio":"","short_translation":"Nuôi Dưỡng","senses":[{"pos":"Noun","definition":"A foster parent.","translation":"Cha mẹ nuôi.","examples":[{"en":"Some fosters end up adopting.","vi":""}]},{"pos":"Noun","definition":"The care given to another; guardianship.","translation":"Sự chăm sóc dành cho người khác; quyền giám hộ.","examples":[]},{"pos":"Verb","definition":"To nurture or bring up offspring, or to provide similar parental care to an unrelated child.","translation":"Để nuôi dưỡng hoặc nuôi dạy con cái hoặc cung cấp sự chăm sóc tương tự của cha mẹ cho một đứa trẻ không có quan hệ họ hàng.","examples":[]},{"pos":"Verb","definition":"To cultivate and grow something.","translation":"Để trồng trọt và phát triển một cái gì đó.","examples":[{"en":"Our company fosters an appreciation for the arts.","vi":""}]},{"pos":"Adjective","definition":"Providing parental care to children not related to oneself.","translation":"Cung cấp sự chăm sóc của cha mẹ cho những đứa trẻ không liên quan đến mình.","examples":[{"en":"foster parents","vi":""}]},{"pos":"Adjective","definition":"Receiving such care.","translation":"Nhận được sự quan tâm như vậy.","examples":[{"en":"a foster child","vi":""}]}],"source":"Free Dictionary API"}{"word":"choose","us_ipa":"/t͡ʃuːz/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/choose-1-us.mp3","uk_audio":"","short_translation":"Chọn","senses":[{"pos":"Verb","definition":"To pick; to make the choice of; to select.","translation":"Để chọn; để đưa ra lựa chọn; để chọn.","examples":[{"en":"I chose a nice ripe apple from the fruit bowl.","vi":""}]},{"pos":"Verb","definition":"To elect.","translation":"Để bầu cử.","examples":[{"en":"He was chosen as president in 1990.","vi":""}]},{"pos":"Conjunction","definition":"The binomial coefficient of the previous and following number.","translation":"Hệ số nhị thức của số trước và số sau.","examples":[]}],"source":"Free Dictionary API"}{"word":"good","us_ipa":"[ɡɪ̈d]","uk_ipa":"/ɡʊ(d)/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/good-us.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/good-uk.mp3","short_translation":"Tốt","senses":[{"pos":"Adjective","definition":"(of people)","translation":"(của mọi người)","examples":[]},{"pos":"Adjective","definition":"(of capabilities)","translation":"(về khả năng)","examples":[]},{"pos":"Interjection","definition":"That is good; an elliptical exclamation of satisfaction or commendation.","translation":"Điều đó tốt; một dấu chấm than hình elip của sự hài lòng hoặc khen ngợi","examples":[{"en":"Good! I can leave now.","vi":""}]}],"source":"Free Dictionary API"}{"word":"behavior","us_ipa":"[bɪˈheɪvjə]","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Hành Vi","senses":[{"pos":"Noun","definition":"Human conduct relative to social norms.","translation":"Hành vi của con người liên quan đến các chuẩn mực xã hội.","examples":[]},{"pos":"Noun","definition":"The way a living creature behaves or acts generally.","translation":"Cách một sinh vật sống cư xử hoặc hành động nói chung.","examples":[]}],"source":"Free Dictionary API"}{"word":"china","us_ipa":"/tʃʌɪnə/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/china-au.mp3","uk_audio":"","short_translation":"Trung Quốc","senses":[{"pos":"Noun","definition":"The plant Smilax china, a liana of much of eastern Asia.","translation":"Cây Smilax china, một loại dây leo có ở phần lớn Đông Á.","examples":[]},{"pos":"Noun","definition":"A plant or flower of the repeat-blooming Chinese rose species Rosa chinensis.","translation":"Một loại cây hoặc hoa của loài hoa hồng Trung Quốc nở lặp lại Rosa chinensis.","examples":[]},{"pos":"Noun","definition":"A plant or flower of one of the class of hybrids developed from Rosa chinensis.","translation":"Một loại cây hoặc hoa thuộc một trong những loại cây lai được phát triển từ Rosa chinensis.","examples":[]},{"pos":"Noun","definition":"Hibiscus rosa-sinensis, native to east Asia.","translation":"Hibiscus rosa-sinensis, có nguồn gốc từ Đông Á.","examples":[]},{"pos":"Noun","definition":"Chinaware: porcelain tableware.","translation":"Đồ sứ: bộ đồ ăn bằng sứ.","examples":[{"en":"He set the table with china, cloth napkins, and crystal stemware.","vi":""}]},{"pos":"Noun","definition":"Cheaper and lower-quality ceramic and ceramic tableware, distinguished from porcelain.","translation":"Bộ đồ ăn bằng gốm và gốm rẻ hơn và chất lượng thấp hơn, khác với đồ sứ.","examples":[]},{"pos":"Noun","definition":"A small gastropod (Monetaria moneta, syn. Cypraea moneta) common in the Indian Ocean; its shell.","translation":"Một loài chân bụng nhỏ (Monetaria moneta, đồng nghĩa Cypraea moneta) phổ biến ở Ấn Độ Dương; vỏ của nó.","examples":[]},{"pos":"Noun","definition":"(by extension) Any gastropod of the genus Cypraea; its shell.","translation":"(bằng cách mở rộng) Bất kỳ loài chân bụng nào thuộc chi Cypraea; vỏ của nó.","examples":[]},{"pos":"Noun","definition":"A person other than a family member, spouse or lover whose company one enjoys and towards whom one feels affection.","translation":"Một người không phải là thành viên trong gia đình, vợ/chồng hoặc người yêu mà mình thích bầu bạn và có cảm tình với người đó.","examples":[{"en":"John and I have been friends ever since we were roommates at college.   Trust is important between friends.   I used to find it hard to make friends when I was shy.","vi":""}]},{"pos":"Noun","definition":"An associate who provides assistance.","translation":"Một cộng sự cung cấp sự trợ giúp.","examples":[{"en":"The Automobile Association is every motorist's friend.   The police is every law-abiding citizen's friend.","vi":""}]},{"pos":"Noun","definition":"A fine clay, rich in kaolinite, used in ceramics, paper-making, etc.","translation":"Là loại đất sét mịn, giàu kaolinit, dùng làm gốm sứ, làm giấy, v.v.","examples":[]},{"pos":"Noun","definition":"(usually uncountable) A hard white translucent ceramic, originally made by firing kaolin, quartz, and feldspar at high temperatures but now also inclusive of similar artificial materials; also often such a material as a symbol of the fragility, elegance, etc. traditionally associated with porcelain goods.","translation":"(thường không đếm được) Một loại gốm cứng trong mờ màu trắng, ban đầu được làm bằng cách nung cao lanh, thạch anh và fenspat ở nhiệt độ cao nhưng bây giờ cũng bao gồm các vật liệu nhân tạo tương tự; cũng thường là chất liệu tượng trưng cho sự mong manh, sang trọng, v.v., theo truyền thống gắn liền với đồ sứ.","examples":[{"en":"Tableware and toilets are both made of porcelain.","vi":""}]},{"pos":"Noun","definition":"(now usually plural) An object made of porcelain, art objects or items of tableware.","translation":"(bây giờ thường là số nhiều) Đồ vật làm bằng sứ, đồ vật nghệ thuật hoặc đồ dùng trên bàn ăn.","examples":[{"en":"The museum has an extensive collection of rare Chinese porcelains.","vi":""}]},{"pos":"Noun","definition":"Small beads made from polished shells, especially white ones, formerly used as money and jewelry by certain Native American peoples.","translation":"Những hạt nhỏ làm từ vỏ sò được đánh bóng, đặc biệt là những hạt màu trắng, trước đây được một số dân tộc bản địa châu Mỹ sử dụng làm tiền và đồ trang sức.","examples":[]},{"pos":"Noun","definition":"A string of such beads.","translation":"Một chuỗi hạt như vậy.","examples":[]}],"source":"Free Dictionary API"}{"word":"models","us_ipa":"/ˈmɒdl̩s/","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Mô Hình","senses":[{"pos":"Noun","definition":"A person who serves as a subject for artwork or fashion, usually in the medium of photography but also for painting or drawing.","translation":"Người đóng vai trò là chủ đề cho tác phẩm nghệ thuật hoặc thời trang, thường là trong lĩnh vực nhiếp ảnh nhưng cũng có thể dùng để vẽ hoặc vẽ.","examples":[{"en":"The beautiful model had her face on the cover of almost every fashion magazine imaginable.","vi":""}]},{"pos":"Noun","definition":"A person, usually an attractive female, hired to show items or goods to the public, such as items given away as prizes on a TV game show.","translation":"Một người, thường là một phụ nữ hấp dẫn, được thuê để giới thiệu các vật phẩm hoặc hàng hóa cho công chúng, chẳng hạn như các vật phẩm được tặng làm giải thưởng trong một chương trình trò chơi truyền hình.","examples":[]},{"pos":"Verb","definition":"To display for others to see, especially in regard to wearing clothing while performing the role of a fashion model","translation":"Để trưng bày cho người khác xem, nhất là về việc mặc quần áo khi làm người mẫu thời trang","examples":[{"en":"She modelled the shoes for her friends to see.","vi":""}]},{"pos":"Verb","definition":"To use as an object in the creation of a forecast or model","translation":"Để sử dụng làm đối tượng trong việc tạo dự báo hoặc mô hình","examples":[{"en":"They modelled the data with a computer to analyze the experiment’s results.","vi":""}]}],"source":"Free Dictionary API"}{"word":"anti","us_ipa":"/ˈæn.ti/","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Chống","senses":[{"pos":"Noun","definition":"A person opposed to a concept or principle.","translation":"Một người phản đối một khái niệm hoặc nguyên tắc.","examples":[]},{"pos":"Adjective","definition":"Opposed to something.","translation":"Đối lập với một cái gì đó.","examples":[]},{"pos":"Adjective","definition":"That has a torsion angle between 90° and 180°","translation":"Có góc xoắn từ 90° đến 180°","examples":[]},{"pos":"Preposition","definition":"Alternative form of anti-","translation":"Hình thức chống thay thế","examples":[]}],"source":"Free Dictionary API"}{"word":"booty","us_ipa":"/ˈbuːti/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/booty-au.mp3","uk_audio":"","short_translation":"Chiến Lợi Phẩm","senses":[{"pos":"Noun","definition":"A form of prize which, when a ship was captured at sea, could be distributed at once.","translation":"Một hình thức giải thưởng mà khi một con tàu bị bắt trên biển, có thể được phân phát ngay lập tức.","examples":[]},{"pos":"Noun","definition":"Plunder taken from an enemy in time of war, or seized by piracy.","translation":"Cướp bóc của kẻ thù trong thời chiến hoặc bị cướp biển chiếm giữ.","examples":[]}],"source":"Free Dictionary API"}{"word":"view","us_ipa":"/vjuː/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/view-us.mp3","uk_audio":"","short_translation":"Xem","senses":[{"pos":"Noun","definition":"(physical) Visual perception.","translation":"(Vật lý) Nhận thức trực quan.","examples":[]},{"pos":"Noun","definition":"A picture, drawn or painted; a sketch.","translation":"Một bức tranh, được vẽ hoặc sơn; một bản phác thảo.","examples":[{"en":"a fine view of Lake George","vi":""}]},{"pos":"Verb","definition":"To look at.","translation":"Để nhìn vào.","examples":[{"en":"The video was viewed by millions of people.","vi":""}]},{"pos":"Verb","definition":"To regard in a stated way.","translation":"Để xem xét một cách đã nêu.","examples":[{"en":"I view it as a serious breach of trust.","vi":""}]}],"source":"Free Dictionary API"}{"word":"fuck","us_ipa":"/fʊk/","uk_ipa":"/fʌk/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/fuck-us.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/fuck-uk.mp3","short_translation":"Chết Tiệt","senses":[{"pos":"Noun","definition":"An act of sexual intercourse.","translation":"Một hành vi quan hệ tình dục.","examples":[]},{"pos":"Noun","definition":"A sexual partner, especially a casual one.","translation":"Một đối tác tình dục, đặc biệt là một người bình thường.","examples":[]},{"pos":"Verb","definition":"To have sexual intercourse, to copulate.","translation":"Để có quan hệ tình dục, để giao hợp.","examples":[{"en":"Fighting for peace is like fucking for virginity.","vi":""}]},{"pos":"Verb","definition":"To have sexual intercourse with.","translation":"Để có quan hệ tình dục với.","examples":[]},{"pos":"Adverb","definition":"Used as an intensifier for the words \"yes\" and \"no\".","translation":"Dùng để tăng cường cho các từ \"có\" và \"không\".","examples":[{"en":"Do you censor your swearing? – Fuck no.","vi":""}]},{"pos":"Interjection","definition":"Expressing dismay or discontent.","translation":"Thể hiện sự thất vọng hoặc bất mãn.","examples":[{"en":"Fuck! Why do you have to be so difficult all the time?","vi":""}]},{"pos":"Interjection","definition":"Expressing surprise.","translation":"Bày tỏ sự ngạc nhiên.","examples":[{"en":"Fuck! That movie was good.","vi":""}]}],"source":"Free Dictionary API"}{"word":"expect","us_ipa":"/ɛkˈspɛkt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/expect-us.mp3","uk_audio":"","short_translation":"Trông Chờ","senses":[{"pos":"Verb","definition":"To predict or believe that something will happen","translation":"Dự đoán hoặc tin rằng điều gì đó sẽ xảy ra","examples":[{"en":"He never expected to be discovered.","vi":""}]},{"pos":"Verb","definition":"To consider obligatory or required.","translation":"Để xem xét bắt buộc hoặc bắt buộc.","examples":[]}],"source":"Free Dictionary API"}{"word":"move","us_ipa":"/muːv/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/move-us.mp3","uk_audio":"","short_translation":"Di Chuyển","senses":[{"pos":"Noun","definition":"The act of moving; a movement.","translation":"Hành động di chuyển; một phong trào.","examples":[{"en":"A slight move of the tiller, and the boat will go off course.","vi":""}]},{"pos":"Noun","definition":"An act for the attainment of an object; a step in the execution of a plan or purpose.","translation":"Hành động nhằm đạt được một mục tiêu; một bước trong việc thực hiện một kế hoạch hoặc mục đích","examples":[{"en":"He made another move towards becoming a naturalized citizen.","vi":""}]},{"pos":"Verb","definition":"To change place or posture; to go, in any manner, from one place or position to another.","translation":"Thay đổi địa điểm hoặc tư thế; đi, bằng bất cứ cách nào, từ nơi này hoặc vị trí này đến nơi khác.","examples":[{"en":"A ship moves rapidly.","vi":""}]},{"pos":"Verb","definition":"To act; to take action; to begin to act","translation":"Để hành động; hành động; bắt đầu hành động","examples":[{"en":"Come on guys, let's move: there's work to do!","vi":""}]}],"source":"Free Dictionary API"}{"word":"television","us_ipa":"/ˈtɛləˌvɪʒən/","uk_ipa":"/ˈtɛləˌvɪʒən/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/television-us.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/television-uk.mp3","short_translation":"Tivi","senses":[{"pos":"Noun","definition":"An electronic communication medium that allows the transmission of real-time visual images, and often sound.","translation":"Một phương tiện truyền thông điện tử cho phép truyền hình ảnh trực quan theo thời gian thực và thường là âm thanh.","examples":[{"en":"It’s a good thing that television doesn’t transmit smell.","vi":""}]},{"pos":"Noun","definition":"A device for receiving television signals and displaying them in visual form.","translation":"Thiết bị thu tín hiệu truyền hình và hiển thị chúng dưới dạng hình ảnh.","examples":[{"en":"I have an old television in the study.","vi":""}]},{"pos":"Verb","definition":"To watch television.","translation":"Để xem tivi.","examples":[]}],"source":"Free Dictionary API"}{"word":"experiment","us_ipa":"/ɛk.ˈspɛ.ɹɪ.mənt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/experiment-us.mp3","uk_audio":"","short_translation":"Cuộc Thí Nghiệm","senses":[{"pos":"Noun","definition":"A test under controlled conditions made to either demonstrate a known truth, examine the validity of a hypothesis, or determine the efficacy of something previously untried.","translation":"Một thử nghiệm trong các điều kiện được kiểm soát được thực hiện để chứng minh một sự thật đã biết, kiểm tra tính hợp lệ của một giả thuyết hoặc xác định tính hiệu quả của một điều gì đó chưa được thử nghiệm trước đây.","examples":[]},{"pos":"Noun","definition":"Experience, practical familiarity with something.","translation":"Kinh nghiệm, sự quen thuộc thực tế với một cái gì đó.","examples":[]},{"pos":"Verb","definition":"To conduct an experiment.","translation":"Để tiến hành một thí nghiệm.","examples":[]},{"pos":"Verb","definition":"To experience; to feel; to perceive; to detect.","translation":"Để trải nghiệm; cảm nhận; để nhận thức; để phát hiện.","examples":[]}],"source":"Free Dictionary API"}{"word":"allow","us_ipa":"/əˈlaʊ/","uk_ipa":"/əˈlaʊ/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/allow-us.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/allow-uk.mp3","short_translation":"Cho Phép","senses":[{"pos":"Verb","definition":"To grant, give, admit, accord, afford, or yield; to let one have.","translation":"Cấp, cho, thừa nhận, chấp thuận, đủ khả năng hoặc mang lại; để cho một người có.","examples":[{"en":"to allow a servant his liberty;  to allow a free passage;  to allow one day for rest","vi":""}]},{"pos":"Verb","definition":"To acknowledge; to accept as true; to concede; to accede to an opinion.","translation":"Để thừa nhận; chấp nhận là đúng; thừa nhận; để tán thành một ý kiến.","examples":[{"en":"to allow a right;  to allow a claim;  to allow the truth of a proposition","vi":""}]}],"source":"Free Dictionary API"}{"word":"concrete","us_ipa":"/kɵnˈkɹiːt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/concrete-us.mp3","uk_audio":"","short_translation":"Bê Tông","senses":[{"pos":"Noun","definition":"A solid mass formed by the coalescence of separate particles; a compound substance, a concretion.","translation":"Một khối rắn được hình thành do sự kết hợp của các hạt riêng biệt; một chất hợp chất, một chất kết tụ.","examples":[]},{"pos":"Noun","definition":"Specifically, a building material created by mixing cement, water, and aggregate such as gravel and sand.","translation":"Cụ thể là vật liệu xây dựng được tạo ra bằng cách trộn xi măng, nước và cốt liệu như sỏi và cát.","examples":[{"en":"The road was made of concrete that had been poured in large slabs.","vi":""}]},{"pos":"Verb","definition":"(usually transitive) To cover with or encase in concrete (building material).","translation":"(thường là bắc cầu) Để che phủ hoặc bọc trong bê tông (vật liệu xây dựng).","examples":[{"en":"I hate grass, so I concreted over my lawn.","vi":""}]},{"pos":"Verb","definition":"(usually transitive) To solidify: to change from being abstract to being concrete (actual, real).","translation":"(thường bắc cầu) Củng cố: chuyển từ trừu tượng sang cụ thể (thực tế, có thực).","examples":[]},{"pos":"Adjective","definition":"Real, actual, tangible.","translation":"Thực tế, thực tế, hữu hình.","examples":[{"en":"Fuzzy videotapes and distorted sound recordings are not concrete evidence that bigfoot exists.","vi":""}]},{"pos":"Adjective","definition":"Being or applying to actual things, not abstract qualities or categories.","translation":"Hiện hữu hoặc áp dụng cho những sự vật thực tế, không phải những phẩm chất hay phạm trù trừu tượng.","examples":[]}],"source":"Free Dictionary API"}{"word":"grey","us_ipa":"/ɡɹeɪ/","uk_ipa":"/ɡɹeɪ/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/grey-us.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/grey-uk.mp3","short_translation":"Xám","senses":[{"pos":"Adjective","definition":"Having a color.","translation":"Có một màu sắc.","examples":[{"en":"Wash colored items separately from whites and darks to prevent the colors from bleeding.","vi":""}]},{"pos":"Adjective","definition":"Having a particular color or kind of color.","translation":"Có một màu sắc hoặc loại màu cụ thể.","examples":[{"en":"The room was red, with a dark-colored rug.","vi":""}]},{"pos":"Noun","definition":"An achromatic colour intermediate between black and white.","translation":"Một màu sắc trung gian giữa đen và trắng.","examples":[]},{"pos":"Noun","definition":"An animal or thing of grey colour, such as a horse, badger, or salmon.","translation":"Động vật hoặc vật có màu xám, chẳng hạn như ngựa, lửng hoặc cá hồi.","examples":[]},{"pos":"Verb","definition":"To become grey.","translation":"Trở nên xám xịt.","examples":[{"en":"My hair is beginning to grey.","vi":""}]},{"pos":"Verb","definition":"To cause to become grey.","translation":"Gây ra màu xám.","examples":[]},{"pos":"Adjective","definition":"Having a color somewhere between white and black, as the ash of an ember.","translation":"Có màu ở đâu đó giữa trắng và đen, giống như tro của than hồng.","examples":[]},{"pos":"Adjective","definition":"Dreary, gloomy.","translation":"Buồn tẻ, ảm đạm.","examples":[]}],"source":"Free Dictionary API"}{"word":"bodies","us_ipa":"","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Thi Thể","senses":[{"pos":"Noun","definition":"Physical frame.","translation":"Khung vật lý","examples":[]},{"pos":"Noun","definition":"Main section.","translation":"Phần chính.","examples":[]},{"pos":"Verb","definition":"To give body or shape to something.","translation":"Tạo cơ thể hoặc hình dạng cho một cái gì đó.","examples":[]},{"pos":"Verb","definition":"To construct the bodywork of a car.","translation":"Để tạo nên thân xe ô tô.","examples":[]}],"source":"Free Dictionary API"}{"word":"tone","us_ipa":"/təʊn/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/tone-1-us.mp3","uk_audio":"","short_translation":"Giai Điệu","senses":[{"pos":"Noun","definition":"A specific pitch.","translation":"Một cao độ cụ thể.","examples":[]},{"pos":"Noun","definition":"(in the diatonic scale) An interval of a major second.","translation":"(trong thang âm nguyên) Khoảng của giây trưởng.","examples":[]},{"pos":"Verb","definition":"To give a particular tone to","translation":"Để tạo ra một giai điệu cụ thể cho","examples":[]},{"pos":"Verb","definition":"To change the colour of","translation":"Để thay đổi màu sắc của","examples":[]}],"source":"Free Dictionary API"}{"word":"variable","us_ipa":"/ˈvɛəɹ.i.ə.bl̩/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/variable-us.mp3","uk_audio":"","short_translation":"Biến","senses":[{"pos":"Noun","definition":"Something that is variable.","translation":"Một cái gì đó có thể thay đổi.","examples":[]},{"pos":"Noun","definition":"Something whose value may be dictated or discovered.","translation":"Một cái gì đó có giá trị có thể được quyết định hoặc phát hiện.","examples":[{"en":"There are several variables to consider here.","vi":""}]},{"pos":"Adjective","definition":"Able to vary or be varied.","translation":"Có thể thay đổi hoặc thay đổi.","examples":[{"en":"variable winds or seasons; a variable quantity; a variable resistor","vi":""}]},{"pos":"Adjective","definition":"Likely to vary.","translation":"Có khả năng khác nhau.","examples":[]}],"source":"Free Dictionary API"}{"word":"typhoon","us_ipa":"/taɪˈfuːn/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/typhoon-au.mp3","uk_audio":"","short_translation":"Cơn Bão","senses":[{"pos":"Noun","definition":"A weather phenomenon in the northwestern Pacific that is precisely equivalent to a hurricane, which results in wind speeds of 64 knots (118 km/h) or above. Equivalent to a cyclone in the Indian Ocean and Indonesia/Australia.","translation":"Một hiện tượng thời tiết ở tây bắc Thái Bình Dương tương đương chính xác với một cơn bão, tạo ra tốc độ gió từ 64 hải lý/giờ (118 km/h) trở lên. Tương đương với một cơn bão ở Ấn Độ Dương và Indonesia/Úc.","examples":[]},{"pos":"Verb","definition":"To swirl like a hurricane.","translation":"Để cuộn xoáy như một cơn cuồng phong.","examples":[]}],"source":"Free Dictionary API"}{"word":"structural","us_ipa":"","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Cấu Trúc","senses":[{"pos":"Noun","definition":"Structural steel, used in construction.","translation":"Kết cấu thép, dùng trong xây dựng.","examples":[]},{"pos":"Adjective","definition":"Of, relating to, or having structure.","translation":"Của, liên quan đến, hoặc có cấu trúc.","examples":[]},{"pos":"Adjective","definition":"Involving the mechanics of construction.","translation":"Liên quan đến cơ khí xây dựng.","examples":[]}],"source":"Free Dictionary API"}{"word":"giant","us_ipa":"/ˈdʒaɪ.ənt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/giant-us.mp3","uk_audio":"","short_translation":"Người Khổng Lồ","senses":[{"pos":"Noun","definition":"A mythical human of very great size.","translation":"Một con người thần thoại có kích thước rất lớn.","examples":[]},{"pos":"Noun","definition":"Specifically, any of the gigantes, the race of giants in the Greek mythology.","translation":"Cụ thể là bất kỳ người khổng lồ nào, chủng tộc người khổng lồ trong thần thoại Hy Lạp.","examples":[]},{"pos":"Adjective","definition":"Very large.","translation":"Rất lớn.","examples":[]}],"source":"Free Dictionary API"}{"word":"nigger","us_ipa":"/ˈnɪɡə(ɹ)/","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Người Da Đen","senses":[{"pos":"Noun","definition":"(see usage notes) A black person; a person of black African descent.","translation":"(xem ghi chú sử dụng) Người da đen; một người gốc Phi da đen.","examples":[]},{"pos":"Noun","definition":"(see usage notes) A member of another typically dark-skinned people (now especially in combinations, e.g. prairie nigger, sand nigger).","translation":"(xem ghi chú sử dụng) Một thành viên của một nhóm người da đen điển hình khác (đặc biệt là trong các nhóm kết hợp, ví dụ: người da đen thảo nguyên, người da đen cát).","examples":[]},{"pos":"Verb","definition":"To clear land by laying light pieces of round timber across the trunks of the trees and setting fire to them at the point of contact, by which means the trees are slowly burned through.","translation":"Giải phóng mặt bằng bằng cách đặt những miếng gỗ tròn nhẹ ngang qua thân cây rồi đốt ở chỗ tiếp xúc, nghĩa là cây sẽ bị cháy từ từ.","examples":[]},{"pos":"Verb","definition":"To exhaust (soil) by cropping it year by year without manure.","translation":"Làm cạn kiệt (đất) bằng cách thu hoạch hàng năm mà không có phân bón.","examples":[]}],"source":"Free Dictionary API"}{"word":"feel","us_ipa":"/fiːl/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/feel-us.mp3","uk_audio":"","short_translation":"Cảm Thấy","senses":[{"pos":"Noun","definition":"A quality of an object experienced by touch.","translation":"Tính chất của một đối tượng được cảm nhận bằng xúc giác.","examples":[{"en":"Bark has a rough feel.","vi":""}]},{"pos":"Noun","definition":"A vague mental impression.","translation":"Một ấn tượng tinh thần mơ hồ.","examples":[{"en":"You should get a feel of the area before moving in.","vi":""}]},{"pos":"Verb","definition":"(heading) To use or experience the sense of touch.","translation":"(tiêu đề) Sử dụng hoặc trải nghiệm cảm giác xúc giác.","examples":[]},{"pos":"Verb","definition":"(heading) To sense or think emotionally or judgmentally.","translation":"(tiêu đề) Cảm nhận hoặc suy nghĩ theo cảm xúc hoặc phán xét.","examples":[]}],"source":"Free Dictionary API"}{"word":"fat","us_ipa":"/fæt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/fat-us.mp3","uk_audio":"","short_translation":"Mập","senses":[{"pos":"Noun","definition":"A specialized animal tissue with a high oil content, used for long-term storage of energy.","translation":"Một loại mô động vật chuyên biệt có hàm lượng dầu cao, được sử dụng để dự trữ năng lượng lâu dài.","examples":[]},{"pos":"Noun","definition":"A refined substance chemically resembling the oils in animal fat.","translation":"Một chất tinh chế về mặt hóa học giống như dầu trong mỡ động vật.","examples":[]},{"pos":"Verb","definition":"To make fat; to fatten.","translation":"Để làm béo; để vỗ béo.","examples":[{"en":"kill the fatted calf","vi":""}]},{"pos":"Verb","definition":"To become fat; to fatten.","translation":"Trở nên béo; để vỗ béo.","examples":[]},{"pos":"Adjective","definition":"Carrying more fat than usual on one's body; plump; not lean or thin.","translation":"Mang nhiều mỡ hơn bình thường trên cơ thể; đầy đặn; không gầy hoặc gầy.","examples":[{"en":"The fat man had trouble getting through the door.","vi":""}]},{"pos":"Adjective","definition":"Thick.","translation":"Dày.","examples":[{"en":"The fat wallets of the men from the city brought joy to the peddlers.","vi":""}]},{"pos":"Adjective","definition":"(originally African American Vernacular English) Excellent; cool; very good.","translation":"(ban đầu là tiếng Anh bản ngữ của người Mỹ gốc Phi) Xuất sắc; mát mẻ; rất tốt.","examples":[]},{"pos":"Adjective","definition":"Sexy.","translation":"Gợi cảm.","examples":[]}],"source":"Free Dictionary API"}{"word":"tiny","us_ipa":"/ˈtaɪni/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/tiny-us.mp3","uk_audio":"","short_translation":"Nhỏ Xíu","senses":[{"pos":"Noun","definition":"A small child; an infant.","translation":"Một đứa trẻ nhỏ; một đứa trẻ sơ sinh.","examples":[]},{"pos":"Noun","definition":"Anything very small.","translation":"Bất cứ điều gì rất nhỏ.","examples":[]},{"pos":"Adjective","definition":"Very small.","translation":"Rất nhỏ.","examples":[]}],"source":"Free Dictionary API"}{"word":"coffee","us_ipa":"/ˈkɑ.fi/","uk_ipa":"/ˈkɒ.fi/","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/coffee-us.mp3","uk_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/coffee-uk.mp3","short_translation":"Cà Phê","senses":[{"pos":"Noun","definition":"A beverage made by infusing the beans of the coffee plant in hot water.","translation":"Một loại đồ uống được làm bằng cách ngâm hạt cà phê trong nước nóng.","examples":[]},{"pos":"Noun","definition":"A serving of this beverage.","translation":"Một khẩu phần đồ uống này.","examples":[]},{"pos":"Verb","definition":"To drink coffee.","translation":"Để uống cà phê.","examples":[]},{"pos":"Adjective","definition":"Of a pale brown colour, like that of milk coffee.","translation":"Có màu nâu nhạt giống cà phê sữa.","examples":[]},{"pos":"Adjective","definition":"Of a table: a small, low table suitable for people in lounge seating to put coffee cups on.","translation":"Bàn: một chiếc bàn nhỏ, thấp thích hợp cho những người ngồi ở ghế dài để đặt tách cà phê.","examples":[]}],"source":"Free Dictionary API"}{"word":"spot","us_ipa":"/spɒt/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/spot-us.mp3","uk_audio":"","short_translation":"Điểm","senses":[{"pos":"Noun","definition":"A round or irregular patch on the surface of a thing having a different color, texture etc. and generally round in shape.","translation":"Một mảng tròn hoặc không đều trên bề mặt của một vật có màu sắc, kết cấu khác, v.v. và thường có hình dạng tròn.","examples":[{"en":"The leopard is noted for the spots of color in its fur.","vi":""}]},{"pos":"Noun","definition":"A stain or disfiguring mark.","translation":"Một vết bẩn hoặc dấu hiệu biến dạng.","examples":[{"en":"I have tried everything, and I can’t get this spot out.","vi":""}]},{"pos":"Verb","definition":"To see, find; to pick out, notice, locate, distinguish or identify.","translation":"Để xem, tìm; để chọn ra, chú ý, xác định vị trí, phân biệt hoặc xác định.","examples":[{"en":"Try to spot the differences between these two pictures.","vi":""}]},{"pos":"Verb","definition":"To loan a small amount of money to someone.","translation":"Cho ai đó vay một số tiền nhỏ.","examples":[{"en":"I’ll spot you ten dollars for lunch.","vi":""}]},{"pos":"Adjective","definition":"Available on the spot; for immediate payment or delivery.","translation":"Có sẵn tại chỗ; để thanh toán ngay hoặc giao hàng.","examples":[{"en":"spot wheat; spot cash; a spot contract","vi":""}]}],"source":"Free Dictionary API"}{"word":"courage","us_ipa":"/ˈkʌɹɪdʒ/","uk_ipa":"","us_audio":"https://api.dictionaryapi.dev/media/pronunciations/en/courage-us.mp3","uk_audio":"","short_translation":"Lòng Can Đảm","senses":[{"pos":"Noun","definition":"The quality of being confident, not afraid or easily intimidated, but without being incautious or inconsiderate.","translation":"Phẩm chất tự tin, không sợ hãi hay dễ bị đe dọa, nhưng không thiếu thận trọng hoặc thiếu cân nhắc.","examples":[{"en":"It takes a lot of courage to be successful in business.","vi":""}]},{"pos":"Noun","definition":"The ability to overcome one's fear, do or live things which one finds frightening.","translation":"Khả năng vượt qua nỗi sợ hãi của một người, làm hoặc sống những điều mà người ta thấy đáng sợ.","examples":[{"en":"He plucked up the courage to tell her how he felt.","vi":""}]},{"pos":"Verb","definition":"To encourage.","translation":"Để khuyến khích.","examples":[]}],"source":"Free Dictionary API"}{"word":"dependencies","us_ipa":"","uk_ipa":"","us_audio":"","uk_audio":"","short_translation":"Sự Phụ Thuộc","senses":[{"pos":"Noun","definition":"A state of dependence; a refusal to exercise initiative.","translation":"Tình trạng lệ thuộc; từ chối thực hiện sáng kiến.","examples":[]},{"pos":"Noun","definition":"Something dependent on, or subordinate to, something else:","translation":"Một cái gì đó phụ thuộc hoặc phụ thuộc vào cái gì khác:","examples":[]}],"source":"Free Dictionary API"}